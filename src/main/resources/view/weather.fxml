<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.chaithanya.skycast.controller.WeatherController"
            stylesheets="@../css/style.css"
            styleClass="background">

    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="card">
            <padding>
                <Insets top="20" right="25" bottom="20" left="25"/>
            </padding>

            <Label text="SkyCast Pro" styleClass="title"/>
            <Label text="Live Weather Intelligence" styleClass="subtitle"/>

            <HBox spacing="10" alignment="CENTER">
                <TextField fx:id="cityField" prefWidth="280"
                           promptText="Search any city..."/>
                <Button text="Search"
                        onAction="#searchWeather"
                        styleClass="searchButton"/>
            </HBox>

            <Separator prefWidth="650"/>

            <HBox spacing="25" alignment="CENTER">
                <VBox alignment="CENTER" spacing="8">
                    <ImageView fx:id="weatherIcon"
                               fitHeight="120"
                               fitWidth="120"
                               preserveRatio="true"/>
                    <Label fx:id="cityLabel" text="City" styleClass="city"/>
                    <Label fx:id="temperatureLabel" text="28°C" styleClass="temperature"/>
                    <Label fx:id="descriptionLabel" text="Description" styleClass="description"/>
                </VBox>

                <GridPane hgap="15" vgap="15">
                    <VBox GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="infoCard">
                        <Label text=" 🌡 Feels Like"/><Label fx:id="feelsLikeLabel"/>
                    </VBox>
                    <VBox GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="infoCard">
                        <Label text=" 💧Humidity"/><Label fx:id="humidityLabel"/>
                    </VBox>
                    <VBox GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="infoCard">
                        <Label text=" 🌬 Wind"/><Label fx:id="windLabel"/>
                    </VBox>
                    <VBox GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="infoCard">
                        <Label text=" 🧭 Pressure"/><Label fx:id="pressureLabel"/>
                    </VBox>
                    <VBox GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="infoCard">
                        <Label text=" 👁 Visibility"/><Label fx:id="visibilityLabel"/>
                    </VBox>
                    <VBox GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="infoCard">
                        <Label text=" 🌍 Country"/><Label fx:id="countryLabel"/>
                    </VBox>
                </GridPane>
            </HBox>

            <HBox spacing="50" alignment="CENTER">
                <VBox alignment="CENTER">
                    <Label text=" 🌅 Sunrise"/>
                    <Label fx:id="sunriseLabel"/>
                </VBox>
                <VBox alignment="CENTER">
                    <Label text=" 🌇Sunset"/>
                    <Label fx:id="sunsetLabel"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
